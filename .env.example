# GraphiCode — environment variables
# Copy to .env.local and fill with values from your Supabase project
# (Dashboard → Project Settings → API). .env.local is gitignored.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — NEVER prefix with NEXT_PUBLIC and never expose to the client.
# Used exclusively by lib/supabase/admin.ts (service-role client).
SUPABASE_SERVICE_ROLE_KEY=
